# Copy this to .env and fill in real values. Never commit .env itself.

DATABASE_URL=postgresql+psycopg2://mealtracker:changeme@localhost:5432/mealtracker

# Used to resolve `date` from `logged_at` at write time (see design doc,
# section on timezone handling). Example: Europe/Copenhagen
DEFAULT_TIMEZONE=Europe/Copenhagen

# Sent as the X-API-Key header on every request. Generate a real random
# value for actual use, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=changeme-generate-a-real-key